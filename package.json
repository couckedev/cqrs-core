{
	"name": "@couckedev/cqrs-core",
	"version": "1.0.0",
	"description": "CQRS minimal SDK",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@eslint/js": "^9.22.0",
		"@types/node": "^26",
		"@vitest/coverage-v8": "^3.0.9",
		"eslint": "^9.22.0",
		"tsup": "^8.3.0",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.26.1",
		"vitest": "^3.0.9"
	},
	"packageManager": "pnpm@10.32.1",
	"engines": {
		"node": ">=18"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/couckedev/cqrs-core.git"
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com",
		"access": "public"
	}
}
